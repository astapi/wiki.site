---
import BaseLayout from '../layouts/BaseLayout.astro'

const games = [
  {
    slug: 'lootdive',
    title: 'LootDive',
    description: '自動戦闘ハクスラRPG。装備・モンスター・ダンジョンデータ。',
  },
]
---
<BaseLayout title="astapi Games Wiki" description="astapi Games の各タイトルのデータリファレンス">
  <div class="max-w-3xl mx-auto px-5 md:px-8 py-16">
    <h1 class="text-3xl md:text-4xl font-semibold mb-3">astapi Games Wiki</h1>
    <p class="text-sm md:text-base text-[var(--color-text-muted)] mb-10">
      各タイトルのデータリファレンスサイト。
    </p>
    <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {games.map((g) => (
        <li>
          <a
            href={`/${g.slug}/`}
            class="block p-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-accent)] transition-colors"
          >
            <h2 class="text-lg font-semibold mb-1">{g.title}</h2>
            <p class="text-xs text-[var(--color-text-muted)]">{g.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
