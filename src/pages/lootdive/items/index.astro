---
import GameLayout from '../../../layouts/GameLayout.astro'

const gameSlug = 'lootdive'
const nav = [
  { href: '/monsters/', label: 'モンスター' },
  { href: '/items/', label: 'アイテム' },
  { href: '/dungeons/', label: 'ダンジョン' },
]
---
<GameLayout title="アイテム一覧 — LootDive Wiki" gameSlug={gameSlug} gameTitle="LootDive" nav={nav}>
  <h1 class="text-2xl md:text-3xl font-semibold mb-3">アイテム一覧</h1>
  <p class="text-sm text-[var(--color-text-muted)]">近日対応予定。</p>
</GameLayout>
