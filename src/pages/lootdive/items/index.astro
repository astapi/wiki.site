---
import GameLayout from '../../../layouts/GameLayout.astro'
import itemsData from '../../../data/lootdive/game/items.json'
import { slotName } from '../../../data/lootdive/i18n'

type Item = {
  id: string
  name: string
  slot: string
  weaponType?: string
  atk?: number
  def?: number
  fixedMods?: { type: string; value: number }[]
}

const gameSlug = 'lootdive'
const nav = [
  { href: '/monsters/', label: 'モンスター' },
  { href: '/items/', label: 'アイテム' },
  { href: '/dungeons/', label: 'ダンジョン' },
  { href: '/system/', label: 'システム' },
]

const slotOrder = ['weapon', 'armor', 'gloves', 'boots', 'accessory']

const rawItems = Object.entries(itemsData.items as Record<string, unknown>)
  .filter(([key, v]) => !key.startsWith('_') && v && typeof v === 'object')
  .map(([, v]) => v as Item)

const bySlot: Record<string, Item[]> = {}
for (const it of rawItems) {
  if (!bySlot[it.slot]) bySlot[it.slot] = []
  bySlot[it.slot].push(it)
}
for (const s of Object.keys(bySlot)) {
  bySlot[s].sort((a, b) => a.name.localeCompare(b.name, 'ja'))
}

const slots = slotOrder.filter((s) => bySlot[s]?.length)
---
<GameLayout
  title="装備・アイテム一覧 | ルートダイブ攻略 wiki"
  description={`ルートダイブの全${rawItems.length}件の装備・アイテムをスロット別(武器・防具・手袋・靴・アクセ)にまとめた一覧。ユニーク装備・固有MODも収録。`}
  keywords="ルートダイブ 装備, ルートダイブ アイテム, ルートダイブ ユニーク, 装備一覧, ルートダイブ攻略, LootDive 装備"
  gameSlug={gameSlug}
  gameTitle="ルートダイブ"
  nav={nav}
>
  <h1 class="text-2xl md:text-3xl font-semibold mb-2">アイテム一覧</h1>
  <p class="text-sm text-[var(--color-text-muted)] mb-6">全 {rawItems.length} 件</p>

  <nav class="flex flex-wrap gap-2 mb-8">
    {slots.map((s) => (
      <a
        href={`#slot-${s}`}
        class="px-3 py-1 text-xs rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-light)]"
      >
        {slotName(s)} ({bySlot[s].length})
      </a>
    ))}
  </nav>

  {slots.map((slot) => (
    <section id={`slot-${slot}`} class="mb-10 scroll-mt-20">
      <h2 class="text-lg font-semibold mb-3 flex items-center gap-2">
        <img src={`/${gameSlug}/images/items/${slot}.png`} alt="" class="w-5 h-5 object-contain" />
        {slotName(slot)}
        <span class="text-xs font-normal text-[var(--color-text-muted)]">({bySlot[slot].length})</span>
      </h2>
      <ul class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2">
        {bySlot[slot].map((it) => (
          <li>
            <a
              href={`/${gameSlug}/items/${it.id}/`}
              class="flex items-center gap-3 p-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-light)] hover:bg-[var(--color-gradient-start)] transition-colors"
            >
              <img
                src={`/${gameSlug}/images/items/${slot === 'weapon' && it.weaponType === 'staff' ? 'staff' : slot}.png`}
                alt=""
                class="w-8 h-8 object-contain shrink-0"
              />
              <div class="min-w-0 flex-1">
                <p class="text-sm truncate">{it.name}</p>
                <p class="text-[11px] text-[var(--color-text-muted)]">
                  {it.atk ? `ATK ${it.atk}` : ''}
                  {it.atk && it.def ? ' / ' : ''}
                  {it.def ? `DEF ${it.def}` : ''}
                  {it.fixedMods?.length ? ' / 固有MOD' : ''}
                </p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}
</GameLayout>
