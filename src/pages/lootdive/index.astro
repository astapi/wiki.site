---
import GameLayout from '../../layouts/GameLayout.astro'
import monstersData from '../../data/lootdive/game/monsters.json'
import itemsData from '../../data/lootdive/game/items.json'
import dungeonsData from '../../data/lootdive/game/dungeons.json'

const gameSlug = 'lootdive'
const gameTitle = 'ルートダイブ'
const nav = [
  { href: '/monsters/', label: 'モンスター' },
  { href: '/items/', label: 'アイテム' },
  { href: '/dungeons/', label: 'ダンジョン' },
  { href: '/system/', label: 'システム' },
]

const monsterCount = Object.entries(monstersData.monsters).filter(
  ([k, v]) => !k.startsWith('_') && v && typeof v === 'object'
).length
const itemCount = Object.entries(itemsData.items).filter(
  ([k, v]) => !k.startsWith('_') && v && typeof v === 'object'
).length
const dungeonCount = Object.entries(dungeonsData.dungeons).filter(
  ([k, v]) => !k.startsWith('_') && !k.startsWith('debug_') && v && typeof v === 'object'
).length

const categories = [
  {
    href: '/monsters/',
    label: 'モンスター',
    desc: '図鑑データ・ステータス・出現ダンジョン・ドロップ',
    count: monsterCount,
  },
  {
    href: '/items/',
    label: 'アイテム',
    desc: '基本ベース・ユニーク装備・固有MOD・入手方法',
    count: itemCount,
  },
  {
    href: '/dungeons/',
    label: 'ダンジョン',
    desc: '階層・敵構成・ボス・ドロップテーブル',
    count: dungeonCount,
  },
  {
    href: '/system/',
    label: 'システム',
    desc: '状態異常・防御機構などバトル計算ルール',
    count: null,
  },
]

const title =
  'ルートダイブ攻略 wiki | 装備・モンスター・ダンジョン完全データベース'
const description = `スマホゲーム「ルートダイブ(LootDive)」の公式攻略wiki。全${itemCount}件の装備、${monsterCount}体のモンスター、${dungeonCount}ダンジョンのマスターデータをまとめたデータベース。自動戦闘ハクスラRPGの周回・ビルド構築の参考に。`
const keywords =
  'ルートダイブ, ルートダイブ攻略, LootDive, LootDive攻略, ハクスラ, ハクスラRPG, 自動戦闘, 放置RPG, 攻略wiki, データベース'

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'ルートダイブ攻略 wiki',
    url: 'https://wiki.astapi.net/lootdive/',
    inLanguage: 'ja',
    description,
    publisher: { '@type': 'Organization', name: 'astapi Games', url: 'https://astapi.net' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'VideoGame',
    name: 'ルートダイブ',
    alternateName: 'LootDive',
    publisher: { '@type': 'Organization', name: 'astapi Games' },
    applicationCategory: 'GameApplication',
    genre: ['Hack and slash', 'Role-playing game', 'Idle game'],
    operatingSystem: ['iOS', 'Android'],
    url: 'https://astapi.net/lootdive',
  },
]
---
<GameLayout
  title={title}
  description={description}
  keywords={keywords}
  gameSlug={gameSlug}
  gameTitle={gameTitle}
  nav={nav}
  jsonLd={jsonLd}
>
  <h1 class="text-2xl md:text-3xl font-semibold mb-2">ルートダイブ攻略 wiki</h1>
  <p class="text-sm md:text-base text-[var(--color-text-muted)] mb-8 leading-relaxed">
    自動戦闘ハクスラRPG「<strong class="font-semibold text-[var(--color-text)]">ルートダイブ</strong>」の
    マスターデータリファレンス。装備・モンスター・ダンジョンの情報を網羅し、
    ビルド構築や周回効率化の参考にどうぞ。
  </p>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    {categories.map((c) => (
      <a
        href={`/${gameSlug}${c.href}`}
        class="block p-5 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-light)] transition-colors"
      >
        <div class="flex items-baseline justify-between mb-1">
          <h2 class="text-base font-semibold">{c.label}</h2>
          {c.count !== null && (
            <span class="text-xs text-[var(--color-text-muted)]">{c.count}件</span>
          )}
        </div>
        <p class="text-xs text-[var(--color-text-muted)]">{c.desc}</p>
      </a>
    ))}
  </div>
</GameLayout>
