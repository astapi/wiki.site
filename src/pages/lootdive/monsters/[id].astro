---
import MonsterDetail from '../../../components/lootdive/MonsterDetail.astro'

type Monster = {
  id?: string
  image: string
  maxHp: number
  atk: number
  def: number
  exp: number
  attackSpeed: number
  isBoss?: boolean
  uniqueDrop?: { itemId: string; dropRate: number } | null
  uniqueDrops?: { itemId: string; dropRate: number }[]
}

export async function getStaticPaths() {
  const data = (await import('../../../data/lootdive/game/monsters.json')).default
  return Object.entries(data.monsters as Record<string, Partial<Monster>>)
    .filter(([key, m]) => !key.startsWith('_') && m.id)
    .map(([, m]) => ({
      params: { id: m.id! },
      props: { monster: m as Monster },
    }))
}

const { monster } = Astro.props as { monster: Monster }
---
<MonsterDetail lang="ja" monster={monster} />
