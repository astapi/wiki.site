---
import GameLayout from '../../../layouts/GameLayout.astro'
import monstersData from '../../../data/lootdive/game/monsters.json'

const gameSlug = 'lootdive'
const nav = [
  { href: '/monsters/', label: 'モンスター' },
  { href: '/items/', label: 'アイテム' },
  { href: '/dungeons/', label: 'ダンジョン' },
]

const monsters = Object.entries(
  monstersData.monsters as Record<string, {
    id?: string
    name: string
    image: string
    maxHp: number
    atk: number
    def: number
  }>
)
  .filter(([key, m]) => !key.startsWith('_') && m.id)
  .map(([, m]) => m as { id: string; name: string; image: string; maxHp: number; atk: number; def: number })
---
<GameLayout title="モンスター一覧 — ルートダイブ wiki" gameSlug={gameSlug} gameTitle="ルートダイブ" nav={nav}>
  <h1 class="text-2xl md:text-3xl font-semibold mb-6">モンスター一覧 ({monsters.length})</h1>
  <ul class="grid grid-cols-2 md:grid-cols-4 gap-3">
    {monsters.map((m) => (
      <li>
        <a
          href={`/${gameSlug}/monsters/${m.id}/`}
          class="flex flex-col items-center gap-2 p-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-light)] hover:bg-[var(--color-gradient-start)] transition-colors"
        >
          <img src={`/${gameSlug}/images/monsters/${m.image}.png`} alt={m.name} class="w-16 h-16 object-contain" loading="lazy" />
          <span class="text-xs text-center">{m.name}</span>
          <span class="text-[10px] text-[var(--color-text-muted)]">HP {m.maxHp} / ATK {m.atk}</span>
        </a>
      </li>
    ))}
  </ul>
</GameLayout>
