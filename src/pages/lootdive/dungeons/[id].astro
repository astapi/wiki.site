---
import GameLayout from '../../../layouts/GameLayout.astro'
import dungeonsData from '../../../data/lootdive/game/dungeons.json'
import monstersData from '../../../data/lootdive/game/monsters.json'
import { itemName, monsterName } from '../../../data/lootdive/i18n'

type Dungeon = {
  id: string
  name: string
  description: string
  maxFloor: number
  monsters?: { monsterId: string; spawnRate: number }[]
  boss?: { monsterId: string; floor: number }
  dropTable?: {
    common?: { itemId: string; dropRate: number }[]
    dungeon?: { itemId: string; dropRate: number }[]
  }
  modTierRange?: { minTier: number; maxTier: number }
  modCountRange?: { min: number; max: number }
  requiresTicket?: boolean
}

type MonsterRef = { id?: string; image?: string }

const gameSlug = 'lootdive'
const nav = [
  { href: '/monsters/', label: 'モンスター' },
  { href: '/items/', label: 'アイテム' },
  { href: '/dungeons/', label: 'ダンジョン' },
]

export async function getStaticPaths() {
  const data = (await import('../../../data/lootdive/game/dungeons.json')).default
  return Object.entries(data.dungeons as Record<string, unknown>)
    .filter(([key, v]) => !key.startsWith('_') && !key.startsWith('debug_') && v && typeof v === 'object' && (v as Dungeon).id)
    .map(([, v]) => ({
      params: { id: (v as Dungeon).id },
      props: { dungeon: v as Dungeon },
    }))
}

const { dungeon } = Astro.props as { dungeon: Dungeon }

const monstersMap = monstersData.monsters as Record<string, MonsterRef>
const monsterImage = (id: string): string | null => {
  const m = monstersMap[id]
  return m && m.image ? `/${gameSlug}/images/monsters/${m.image}.png` : null
}
---
<GameLayout
  title={`${dungeon.name}の攻略・敵構成・ドロップ | ルートダイブ攻略`}
  description={`ルートダイブのダンジョン「${dungeon.name}」(最大${dungeon.maxFloor}階)の出現モンスター、${dungeon.boss ? 'ボス情報、' : ''}ドロップテーブル、MOD Tierをまとめた攻略情報。`}
  keywords={`${dungeon.name}, ${dungeon.name} 攻略, ${dungeon.name} ドロップ, ${dungeon.name} ボス, ルートダイブ ダンジョン, ルートダイブ攻略, LootDive`}
  gameSlug={gameSlug}
  gameTitle="ルートダイブ"
  ogType="article"
  nav={nav}
>
  <a href={`/${gameSlug}/dungeons/`} class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text)]">← ダンジョン一覧</a>

  <header class="mt-4 mb-6">
    <h1 class="text-2xl md:text-3xl font-semibold mb-2">{dungeon.name}</h1>
    <p class="text-sm text-[var(--color-text-muted)] mb-3">{dungeon.description}</p>
    <div class="flex flex-wrap gap-3 text-xs">
      <span class="px-2 py-1 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)]">
        {dungeon.maxFloor}F まで
      </span>
      {dungeon.requiresTicket && (
        <span class="inline-flex items-center h-7 px-3 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] whitespace-nowrap">
          入場チケット必要
        </span>
      )}
      {dungeon.modTierRange && (
        <span class="inline-flex items-center h-7 px-3 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] whitespace-nowrap">
          MOD Tier {dungeon.modTierRange.maxTier}–{dungeon.modTierRange.minTier}
        </span>
      )}
      {dungeon.modCountRange && (
        <span class="inline-flex items-center h-7 px-3 rounded-md border border-[var(--color-border)] bg-[var(--color-surface)] whitespace-nowrap">
          MOD数 {dungeon.modCountRange.min}–{dungeon.modCountRange.max}
        </span>
      )}
    </div>
  </header>

  {dungeon.boss && (
    <section class="mb-8">
      <h2 class="text-base font-semibold mb-3">ボス</h2>
      <a
        href={`/${gameSlug}/monsters/${dungeon.boss.monsterId}/`}
        class="inline-flex items-center gap-3 p-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-light)] hover:bg-[var(--color-gradient-start)] transition-colors"
      >
        {monsterImage(dungeon.boss.monsterId) && (
          <img src={monsterImage(dungeon.boss.monsterId)!} alt="" class="w-10 h-10 object-contain" />
        )}
        <div>
          <p class="text-sm font-medium">{monsterName(dungeon.boss.monsterId)}</p>
          <p class="text-xs text-[var(--color-text-muted)]">{dungeon.boss.floor}F</p>
        </div>
      </a>
    </section>
  )}

  {dungeon.monsters?.length ? (
    <section class="mb-8">
      <h2 class="text-base font-semibold mb-3">出現モンスター</h2>
      <ul class="grid grid-cols-2 md:grid-cols-4 gap-2">
        {dungeon.monsters.map((m) => (
          <li>
            <a
              href={`/${gameSlug}/monsters/${m.monsterId}/`}
              class="flex items-center gap-2 p-2 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-light)] hover:bg-[var(--color-gradient-start)] transition-colors"
            >
              {monsterImage(m.monsterId) && (
                <img src={monsterImage(m.monsterId)!} alt="" class="w-8 h-8 object-contain shrink-0" />
              )}
              <div class="min-w-0">
                <p class="text-xs truncate">{monsterName(m.monsterId)}</p>
                <p class="text-[10px] text-[var(--color-text-muted)]">出現率 {m.spawnRate}%</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ) : null}

  {(dungeon.dropTable?.common?.length || dungeon.dropTable?.dungeon?.length) ? (
    <section class="mb-8">
      <h2 class="text-base font-semibold mb-3">ドロップテーブル</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {dungeon.dropTable.dungeon?.length ? (
          <div>
            <h3 class="text-xs text-[var(--color-text-muted)] mb-2">ダンジョン専用</h3>
            <ul class="space-y-1">
              {dungeon.dropTable.dungeon.map((d) => (
                <li class="flex items-baseline justify-between text-sm px-3 py-2 rounded border border-[var(--color-border)] bg-[var(--color-surface)]">
                  <a href={`/${gameSlug}/items/${d.itemId}/`} class="hover:underline">{itemName(d.itemId)}</a>
                  <span class="text-xs text-[var(--color-text-muted)]">{d.dropRate}%</span>
                </li>
              ))}
            </ul>
          </div>
        ) : null}
        {dungeon.dropTable.common?.length ? (
          <div>
            <h3 class="text-xs text-[var(--color-text-muted)] mb-2">共通</h3>
            <ul class="space-y-1">
              {dungeon.dropTable.common.map((d) => (
                <li class="flex items-baseline justify-between text-sm px-3 py-2 rounded border border-[var(--color-border)] bg-[var(--color-surface)]">
                  <a href={`/${gameSlug}/items/${d.itemId}/`} class="hover:underline">{itemName(d.itemId)}</a>
                  <span class="text-xs text-[var(--color-text-muted)]">{d.dropRate}%</span>
                </li>
              ))}
            </ul>
          </div>
        ) : null}
      </div>
    </section>
  ) : null}
</GameLayout>
