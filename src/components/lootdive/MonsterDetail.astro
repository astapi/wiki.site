---
import GameLayout from '../../layouts/GameLayout.astro'
import itemsData from '../../data/lootdive/game/items.json'
import { itemName, monsterName, slotName } from '../../data/lootdive/i18n'
import { getModDescription } from '../../data/lootdive/modDescription'
import { getBossTips } from '../../data/lootdive/bossTips'
import {
  getBossAbilities,
  isUber,
  isUberUber,
  lookupSkillLabel,
  triggerLabel,
  type BossSkillInfo,
  type SkillTriggerType,
} from '../../data/lootdive/bossSkills'
import { t, localeHref, type Lang } from '../../i18n/site'

type Item = {
  id: string
  slot: string
  weaponType?: string
  atk?: number
  def?: number
  fixedMods?: { type: string; value: number }[]
}

type Drop = { itemId: string; dropRate: number }
type Monster = {
  id: string
  image: string
  maxHp: number
  atk: number
  def: number
  exp: number
  attackSpeed: number
  isBoss?: boolean
  uniqueDrop?: Drop | null
  uniqueDrops?: Drop[]
}

interface Props {
  lang: Lang
  monster: Monster
}
const { lang, monster } = Astro.props

const gameSlug = 'lootdive'
const base = `/${gameSlug}`

const itemsMap = itemsData.items as Record<string, Item | undefined>
const getItem = (id: string): Item | null => {
  const raw = itemsMap[id]
  return raw && typeof raw === 'object' && raw.id ? raw : null
}

const name = monsterName(monster.id, lang)

const uber = isUber(monster.id)
const uberUber = isUberUber(monster.id)
const abilities = uber ? getBossAbilities(monster.id) : null

function filterSkills(list: BossSkillInfo[]): BossSkillInfo[] {
  return list.filter((s) => (s.isUberUberOnly && !uberUber ? false : true))
}
function skillDescKey(s: BossSkillInfo): string {
  return uberUber && s.descKeyUberUber ? s.descKeyUberUber : s.descKey
}
function skillTrigger(s: BossSkillInfo): SkillTriggerType | undefined {
  return uberUber && s.triggerTypeUberUber ? s.triggerTypeUberUber : s.triggerType
}

const regularSkills = abilities ? filterSkills(abilities.regularSkills) : []
const thresholdSkills = abilities ? filterSkills(abilities.thresholdSkills) : []

const drops: Drop[] = monster.uniqueDrops?.length
  ? monster.uniqueDrops
  : monster.uniqueDrop
    ? [monster.uniqueDrop]
    : []

const tips = getBossTips(monster.id, lang)

const skillsPart = abilities ? t(lang, 'monsters.detailDescriptionSkillsPart') : ''
const dropsPart = drops.length > 0 ? t(lang, 'monsters.detailDescriptionDropsPart') : ''

const detailDescription = t(lang, 'monsters.detailDescription', {
  name,
  hp: monster.maxHp,
  atk: monster.atk,
  def: monster.def,
  skillsPart,
  dropsPart,
})
---
<GameLayout
  title={t(lang, 'monsters.detailTitle', { name })}
  description={detailDescription}
  keywords={t(lang, 'monsters.detailKeywords', { name })}
  gameSlug={gameSlug}
  ogType="article"
  lang={lang}
  currentPath={`/monsters/${monster.id}/`}
>
  <a href={localeHref(lang, base, '/monsters/')} class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-text)]">
    {t(lang, 'common.backToMonsters')}
  </a>

  <div class="mt-4 flex items-start gap-6">
    <img src={`/${gameSlug}/images/monsters/${monster.image}.png`} alt={name} class="w-32 h-32 object-contain" />
    <div>
      <h1 class="text-2xl md:text-3xl font-semibold mb-2">{name}</h1>
      <p class="text-xs text-[var(--color-text-muted)] mb-4">{t(lang, 'monsters.idLabel')}: {monster.id}</p>
      <dl class="grid grid-cols-2 gap-x-8 gap-y-1 text-sm">
        <dt class="text-[var(--color-text-muted)]">{t(lang, 'monsters.stats.hp')}</dt><dd>{monster.maxHp}</dd>
        <dt class="text-[var(--color-text-muted)]">{t(lang, 'monsters.stats.atk')}</dt><dd>{monster.atk}</dd>
        <dt class="text-[var(--color-text-muted)]">{t(lang, 'monsters.stats.def')}</dt><dd>{monster.def}</dd>
        <dt class="text-[var(--color-text-muted)]">{t(lang, 'monsters.stats.exp')}</dt><dd>{monster.exp}</dd>
        <dt class="text-[var(--color-text-muted)]">{t(lang, 'monsters.stats.attackSpeed')}</dt><dd>{monster.attackSpeed}</dd>
      </dl>
    </div>
  </div>

  {tips && tips.length > 0 && (
    <section class="mt-8">
      <h2 class="text-base font-semibold mb-3">{t(lang, 'monsters.tipsHeading')}</h2>
      <ul class="p-4 rounded-xl border border-[#FFD166] bg-[#FFF8E1] space-y-2 text-sm leading-relaxed">
        {tips.map((tip) => <li>・{tip}</li>)}
      </ul>
    </section>
  )}

  {abilities && (regularSkills.length > 0 || thresholdSkills.length > 0) && (
    <section class="mt-8">
      <h2 class="text-base font-semibold mb-3">{t(lang, 'monsters.skillsHeading')}</h2>

      {regularSkills.length > 0 && (
        <ul class="space-y-2 mb-4">
          {regularSkills.map((s) => {
            const trigger = triggerLabel(skillTrigger(s), lang)
            return (
              <li class="p-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
                <div class="flex items-baseline justify-between gap-3 mb-1">
                  <span class="text-sm font-medium">{lookupSkillLabel(monster.id, s.skillKey, lang)}</span>
                  {trigger && (
                    <span class="text-[11px] text-[var(--color-text-muted)] shrink-0">{trigger}</span>
                  )}
                </div>
                <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
                  {lookupSkillLabel(monster.id, skillDescKey(s), lang)}
                </p>
              </li>
            )
          })}
        </ul>
      )}

      {thresholdSkills.length > 0 && (
        <ul class="space-y-2">
          {thresholdSkills.map((s) => {
            const trigger = triggerLabel(skillTrigger(s), lang)
            return (
              <li class="p-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
                <div class="flex items-baseline justify-between gap-3 mb-1">
                  <span class="text-sm font-medium">{lookupSkillLabel(monster.id, s.skillKey, lang)}</span>
                  {trigger && (
                    <span class="text-[11px] text-[var(--color-text-muted)] shrink-0">{trigger}</span>
                  )}
                </div>
                <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
                  {lookupSkillLabel(monster.id, skillDescKey(s), lang)}
                </p>
              </li>
            )
          })}
        </ul>
      )}
    </section>
  )}

  {drops.length > 0 && (
    <section class="mt-8">
      <h2 class="text-base font-semibold mb-3">{t(lang, 'monsters.uniqueDropsHeading')}</h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {drops.map((d) => {
          const item = getItem(d.itemId)
          const iconSlug =
            item?.slot === 'weapon' && item.weaponType === 'staff' ? 'staff' : item?.slot
          return (
            <li>
              <a
                href={localeHref(lang, base, `/items/${d.itemId}/`)}
                class="block p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-light)] hover:bg-[var(--color-gradient-start)] transition-colors"
              >
                <div class="flex items-start gap-3">
                  {iconSlug && (
                    <img
                      src={`/${gameSlug}/images/items/${iconSlug}.png`}
                      alt=""
                      class="w-10 h-10 object-contain shrink-0"
                    />
                  )}
                  <div class="flex-1 min-w-0">
                    <div class="flex items-baseline justify-between gap-2 mb-1">
                      <span class="text-sm font-medium">{itemName(d.itemId, lang)}</span>
                      <span class="text-xs text-[var(--color-text-muted)] shrink-0">{d.dropRate}%</span>
                    </div>
                    {item && (
                      <p class="text-[11px] text-[var(--color-text-muted)]">
                        {slotName(item.slot, lang)}
                        {item.atk !== undefined && item.atk !== 0 && ` / ATK ${item.atk}`}
                        {item.def !== undefined && item.def !== 0 && ` / DEF ${item.def}`}
                      </p>
                    )}
                  </div>
                </div>
                {item?.fixedMods?.length ? (
                  <ul class="mt-2 ml-13 space-y-0.5 text-xs text-[#9370DB]">
                    {item.fixedMods.map((m) => {
                      const desc = getModDescription(m, lang)
                      return desc ? <li>• {desc}</li> : null
                    })}
                  </ul>
                ) : null}
              </a>
            </li>
          )
        })}
      </ul>
    </section>
  )}
</GameLayout>
