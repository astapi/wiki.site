---
import GameLayout from '../../layouts/GameLayout.astro'
import dungeonsData from '../../data/lootdive/game/dungeons.json'
import { dungeonDescription, dungeonName } from '../../data/lootdive/i18n'
import { t, localeHref, type Lang } from '../../i18n/site'

interface Props {
  lang: Lang
}
const { lang } = Astro.props

type Dungeon = {
  id: string
  maxFloor: number
  requiresTicket?: boolean
}

const gameSlug = 'lootdive'
const base = `/${gameSlug}`

const dungeons = Object.entries(dungeonsData.dungeons as Record<string, unknown>)
  .filter(
    ([key, v]) =>
      !key.startsWith('_') &&
      !key.startsWith('debug_') &&
      v &&
      typeof v === 'object' &&
      (v as Dungeon).id
  )
  .map(([, v]) => v as Dungeon)

const count = dungeons.length
---
<GameLayout
  title={t(lang, 'dungeons.listTitle')}
  description={t(lang, 'dungeons.listDescription', { count })}
  keywords={t(lang, 'dungeons.listKeywords')}
  gameSlug={gameSlug}
  lang={lang}
  currentPath="/dungeons/"
>
  <h1 class="text-2xl md:text-3xl font-semibold mb-2">{t(lang, 'dungeons.listHeading')}</h1>
  <p class="text-sm text-[var(--color-text-muted)] mb-6">{t(lang, 'dungeons.listTotal', { count })}</p>

  <ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {dungeons.map((d) => (
      <li>
        <a
          href={localeHref(lang, base, `/dungeons/${d.id}/`)}
          class="block p-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-border-light)] hover:bg-[var(--color-gradient-start)] transition-colors"
        >
          <div class="flex items-baseline justify-between gap-2 mb-1">
            <h2 class="text-base font-semibold">{dungeonName(d.id, lang)}</h2>
            <span class="text-xs text-[var(--color-text-muted)] shrink-0">
              {d.maxFloor}{t(lang, 'dungeons.floorUnit')}
              {d.requiresTicket && ` / ${t(lang, 'dungeons.requiresTicketShort')}`}
            </span>
          </div>
          <p class="text-xs text-[var(--color-text-muted)] line-clamp-2">{dungeonDescription(d.id, lang)}</p>
        </a>
      </li>
    ))}
  </ul>
</GameLayout>
